-- iOS storage schema. Mirrors the Android Room v8 schema exactly so a
-- contact list created on Android (then exported to iOS via QR / hash
-- import) renders identically. Phase 2 work — only iOS instantiates
-- this database; Android keeps using Room.

-- ---- identity ------------------------------------------------------

CREATE TABLE identity (
    id                  INTEGER NOT NULL PRIMARY KEY DEFAULT 0,
    -- Legacy plaintext columns kept for schema parity with pre-v3
    -- iOS installs. New writes leave these empty / null; the engine
    -- reads from the *Enc columns below. Drop in a future schema
    -- version once we ship a Secure-Enclave-backed iOS vault.
    -- Audit reference: 2026-05-13 HIGH-1 follow-up.
    encPrivKey          BLOB    NOT NULL,
    sigPrivKey          BLOB    NOT NULL,
    ratchetPrivKey      BLOB,
    -- v3 vault-sealed columns. On iOS these currently hold the
    -- plaintext keys (PlaintextIdentityVault); the deferred Secure
    -- Enclave work will swap that for an authenticated-encryption
    -- envelope with no on-disk format change.
    encPrivKeyEnc       BLOB,
    sigPrivKeyEnc       BLOB,
    ratchetPrivKeyEnc   BLOB
);

selectIdentity:
SELECT *
FROM identity
WHERE id = 0
LIMIT 1;

upsertIdentity:
INSERT OR REPLACE INTO identity (
    id, encPrivKey, sigPrivKey, ratchetPrivKey,
    encPrivKeyEnc, sigPrivKeyEnc, ratchetPrivKeyEnc
)
VALUES (0, ?, ?, ?, ?, ?, ?);

-- ---- destinations --------------------------------------------------

CREATE TABLE destinations (
    hash          TEXT    NOT NULL PRIMARY KEY,
    identityHash  TEXT    NOT NULL,
    publicKey     BLOB    NOT NULL,
    destHash      BLOB    NOT NULL,
    nameHash      BLOB    NOT NULL,
    ratchetPub    BLOB,
    displayName   TEXT    NOT NULL,
    appName       TEXT,
    appLabel      TEXT,
    telemetryJson TEXT,
    lat           REAL,
    lon           REAL,
    appDataHex    TEXT    NOT NULL,
    lastSeen      INTEGER NOT NULL,
    rssi          INTEGER,
    favorite      INTEGER NOT NULL,
    source        TEXT    NOT NULL,
    hidden        INTEGER NOT NULL DEFAULT 0,
    hopCount      INTEGER NOT NULL DEFAULT 0,
    nextHop       BLOB,
    userLabel     TEXT
);

upsertDestination:
INSERT OR REPLACE INTO destinations (
    hash, identityHash, publicKey, destHash, nameHash, ratchetPub,
    displayName, appName, appLabel, telemetryJson, lat, lon,
    appDataHex, lastSeen, rssi, favorite, source, hidden, hopCount,
    nextHop, userLabel
) VALUES (
    ?, ?, ?, ?, ?, ?,
    ?, ?, ?, ?, ?, ?,
    ?, ?, ?, ?, ?, ?, ?,
    ?, ?
);

selectDestination:
SELECT *
FROM destinations
WHERE hash = ?
LIMIT 1;

selectAllDestinations:
SELECT *
FROM destinations
WHERE hidden = 0
ORDER BY lastSeen DESC;

observeAllDestinations:
SELECT *
FROM destinations
WHERE hidden = 0
ORDER BY favorite DESC, lastSeen DESC;

setFavorite:
UPDATE destinations
SET favorite = ?, hidden = 0
WHERE hash = ?;

setUserLabel:
UPDATE destinations
SET userLabel = ?
WHERE hash = ?;

hideDestination:
UPDATE destinations
SET hidden = 1
WHERE hash = ?;

deleteAllDestinations:
DELETE FROM destinations;

-- MED-2 announce-flood eviction. Hard-deletes the oldest
-- non-favorited, non-user-labeled, non-hidden rows past
-- the keep count. Favorites and renamed entries are preserved
-- regardless. Audit reference: 2026-05-13 MED-2.
evictUnfavoritedOldest:
DELETE FROM destinations
WHERE hash IN (
    SELECT hash FROM destinations
    WHERE favorite = 0
      AND hidden = 0
      AND (userLabel IS NULL OR userLabel = '')
    ORDER BY lastSeen DESC
    LIMIT -1 OFFSET ?
);

-- ---- messages ------------------------------------------------------

CREATE TABLE messages (
    id                INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    contactHash       TEXT    NOT NULL,
    direction         TEXT    NOT NULL,
    content           TEXT    NOT NULL,
    title             TEXT    NOT NULL,
    timestamp         INTEGER NOT NULL,
    state             TEXT,
    attempts          INTEGER NOT NULL,
    lastAttempt       INTEGER NOT NULL,
    lastError         TEXT,
    rawPacket         BLOB,
    packetHash        TEXT,
    rssi              INTEGER,
    hopCount          INTEGER,
    imageBytes        BLOB,
    -- v1.1.33: reactions + replies. See commonMain
    -- store/Models.kt:StoredMessage kdoc for semantics.
    messageId         TEXT,
    replyToMessageId  TEXT,
    reactionsJson     TEXT,
    -- v1.1.38: relay-aware routing. Set when an inbound LXMF
    -- arrived over a link whose initiator LINKIDENTIFY'd to a
    -- destination differing from the LXMF body's source_hash
    -- (fwdsvc fanout case). sendReaction / sendExistingMessage
    -- route through this destination when set so reactions /
    -- replies reach the whole group instead of egressing direct
    -- to the original sender. Null on legacy rows + 1:1 chats.
    arrivedViaDest    TEXT
);

CREATE INDEX idx_messages_messageId ON messages(messageId);
CREATE INDEX idx_messages_replyToMessageId ON messages(replyToMessageId);

insertMessage:
INSERT INTO messages (
    contactHash, direction, content, title, timestamp, state,
    attempts, lastAttempt, lastError, rawPacket, packetHash, rssi,
    hopCount, imageBytes, messageId, replyToMessageId, reactionsJson,
    arrivedViaDest
) VALUES (
    ?, ?, ?, ?, ?, ?,
    ?, ?, ?, ?, ?, ?,
    ?, ?, ?, ?, ?,
    ?
);

selectMessageByMessageId:
SELECT *
FROM messages
WHERE messageId = ?
LIMIT 1;

setMessageId:
UPDATE messages
SET messageId = :messageId
WHERE id = :rowId;

setReactionsJson:
UPDATE messages
SET reactionsJson = :json
WHERE id = :rowId;

lastInsertRowId:
SELECT last_insert_rowid();

selectMessageById:
SELECT *
FROM messages
WHERE id = ?
LIMIT 1;

-- id ASC tie-break is load-bearing: two messages saved within the same
-- millisecond would otherwise flip order between consecutive observe*
-- emissions, surfacing as "the bubbles reorder themselves" on rapid
-- bursts (e.g. /users reply landing alongside an outgoing drain after
-- a transport reconnect). Mirrors the Room queries in Daos.kt.
selectMessagesForContact:
SELECT *
FROM messages
WHERE contactHash = ?
ORDER BY timestamp ASC, id ASC;

observeMessagesForContact:
SELECT *
FROM messages
WHERE contactHash = ?
ORDER BY timestamp ASC, id ASC;

selectAllMessages:
SELECT *
FROM messages
ORDER BY timestamp ASC, id ASC;

-- Prefix LIKE so both pre-v1.1.22 truncated (32 hex char) and v1.1.22+
-- full (64 hex char) packetHash values match against the inbound
-- PROOF's 32-char truncated dest_hash. The full form is needed by the
-- PROOF handler to Ed25519-verify the sig (SPEC §6.5.5).
selectOutgoingByPacketHash:
SELECT *
FROM messages
WHERE packetHash LIKE :hash || '%' AND direction = 'outgoing'
LIMIT 1;

observeIncomingContactHashes:
SELECT DISTINCT contactHash
FROM messages
WHERE direction = 'incoming';

-- COALESCE-based partial update: each parameter is nullable; passing
-- NULL leaves the column unchanged. Mirrors the Room DAO's
-- updateState() exactly so iOS code calls it identically.
--
-- Named bindings (:state, :attempts, ...) so SQLDelight generates
-- a Kotlin function with those parameter names; without them
-- repeated `?` would generate positional `value`/`value_`/`value__`
-- names that the iOS-side caller can't address by name.
updateMessageState:
UPDATE messages
SET state       = COALESCE(:state,       state),
    attempts    = COALESCE(:attempts,    attempts),
    lastAttempt = COALESCE(:lastAttempt, lastAttempt),
    lastError   = COALESCE(:lastError,   lastError),
    packetHash  = COALESCE(:packetHash,  packetHash)
WHERE id = :id;

deleteMessagesForContact:
DELETE FROM messages
WHERE contactHash = ?;

-- ---- nomad_page_cache ---------------------------------------------

CREATE TABLE nomad_page_cache (
    destHash    TEXT    NOT NULL,
    path        TEXT    NOT NULL,
    source      TEXT    NOT NULL,
    fetchedAt   INTEGER NOT NULL,
    byteSize    INTEGER NOT NULL,
    PRIMARY KEY (destHash, path)
);

upsertCachedPage:
INSERT OR REPLACE INTO nomad_page_cache (destHash, path, source, fetchedAt, byteSize)
VALUES (?, ?, ?, ?, ?);

selectCachedPage:
SELECT *
FROM nomad_page_cache
WHERE destHash = ? AND path = ?
LIMIT 1;

anyCachedForDest:
SELECT EXISTS(
    SELECT 1 FROM nomad_page_cache WHERE destHash = ? LIMIT 1
);

observeCachedDestHashes:
SELECT DISTINCT destHash
FROM nomad_page_cache;

deleteCachedPage:
DELETE FROM nomad_page_cache
WHERE destHash = ? AND path = ?;

deleteCachedForDest:
DELETE FROM nomad_page_cache
WHERE destHash = ?;

deleteAllCached:
DELETE FROM nomad_page_cache;

-- ---- Reticulum Relay Chat (RRC) ------------------------------------
--
-- Experimental chat feature, gated by the off-by-default
-- `experimentalRrc` preference. Three tables — hubs, rooms, room
-- message history — mirroring the commonMain store/RrcModels.kt
-- models and the Android Room rrc_* tables (Room schema v14). Kept
-- separate from the LXMF messages / destinations tables so the
-- feature stays fully isolated behind the flag. `joined` is stored
-- as INTEGER (0/1) and mapped to Boolean in the repository actual,
-- matching how `destinations.favorite` is handled.

CREATE TABLE rrc_hub (
    destHash         TEXT    NOT NULL PRIMARY KEY,
    displayName      TEXT    NOT NULL,
    nick             TEXT,
    lastConnectedAt  INTEGER NOT NULL,
    addedAt          INTEGER NOT NULL
);

upsertRrcHub:
INSERT OR REPLACE INTO rrc_hub (destHash, displayName, nick, lastConnectedAt, addedAt)
VALUES (?, ?, ?, ?, ?);

selectRrcHub:
SELECT *
FROM rrc_hub
WHERE destHash = ?
LIMIT 1;

selectAllRrcHubs:
SELECT *
FROM rrc_hub
ORDER BY lastConnectedAt DESC, addedAt DESC;

setRrcHubLastConnected:
UPDATE rrc_hub
SET lastConnectedAt = :whenMs
WHERE destHash = :destHash;

deleteRrcHub:
DELETE FROM rrc_hub
WHERE destHash = ?;

CREATE TABLE rrc_room (
    hubHash         TEXT    NOT NULL,
    name            TEXT    NOT NULL,
    joined          INTEGER NOT NULL,
    lastActivityAt  INTEGER NOT NULL,
    PRIMARY KEY (hubHash, name)
);

upsertRrcRoom:
INSERT OR REPLACE INTO rrc_room (hubHash, name, joined, lastActivityAt)
VALUES (?, ?, ?, ?);

selectRrcRoomsForHub:
SELECT *
FROM rrc_room
WHERE hubHash = ?
ORDER BY lastActivityAt DESC, name ASC;

setRrcRoomJoined:
UPDATE rrc_room
SET joined = :joined
WHERE hubHash = :hubHash AND name = :name;

-- Forward-only clock bump — an out-of-order older timestamp is
-- rejected by the `lastActivityAt < :activityMs` guard.
touchRrcRoom:
UPDATE rrc_room
SET lastActivityAt = :activityMs
WHERE hubHash = :hubHash AND name = :name AND lastActivityAt < :activityMs;

deleteRrcRoom:
DELETE FROM rrc_room
WHERE hubHash = ? AND name = ?;

deleteRrcRoomsForHub:
DELETE FROM rrc_room
WHERE hubHash = ?;

CREATE TABLE rrc_message (
    id            INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    hubHash       TEXT    NOT NULL,
    room          TEXT    NOT NULL,
    direction     TEXT    NOT NULL,
    senderIdHash  TEXT    NOT NULL,
    nick          TEXT,
    text          TEXT    NOT NULL,
    timestamp     INTEGER NOT NULL,
    msgId         TEXT
);

-- (hubHash, room) covers the room-history read + per-room delete;
-- (hubHash, msgId) covers the echo-dedup existence check.
CREATE INDEX idx_rrc_message_hub_room ON rrc_message(hubHash, room);
CREATE INDEX idx_rrc_message_hub_msgId ON rrc_message(hubHash, msgId);

insertRrcMessage:
INSERT INTO rrc_message (
    hubHash, room, direction, senderIdHash, nick, text, timestamp, msgId
) VALUES (?, ?, ?, ?, ?, ?, ?, ?);

-- timestamp ASC, id ASC — same load-bearing tie-break as the LXMF
-- messages table so same-millisecond rows keep a stable order.
selectRrcMessages:
SELECT *
FROM rrc_message
WHERE hubHash = ? AND room = ?
ORDER BY timestamp ASC, id ASC;

rrcMessageIdExists:
SELECT EXISTS(
    SELECT 1 FROM rrc_message WHERE hubHash = :hubHash AND msgId = :msgId LIMIT 1
);

deleteRrcMessagesForRoom:
DELETE FROM rrc_message
WHERE hubHash = ? AND room = ?;

deleteRrcMessagesForHub:
DELETE FROM rrc_message
WHERE hubHash = ?;
