-- iOS storage schema. Mirrors the Android Room v8 schema exactly so a
-- contact list created on Android (then exported to iOS via QR / hash
-- import) renders identically. Phase 2 work — only iOS instantiates
-- this database; Android keeps using Room.

-- ---- identity ------------------------------------------------------

CREATE TABLE identity (
    id              INTEGER NOT NULL PRIMARY KEY DEFAULT 0,
    encPrivKey      BLOB    NOT NULL,
    sigPrivKey      BLOB    NOT NULL,
    ratchetPrivKey  BLOB
);

selectIdentity:
SELECT *
FROM identity
WHERE id = 0
LIMIT 1;

upsertIdentity:
INSERT OR REPLACE INTO identity (id, encPrivKey, sigPrivKey, ratchetPrivKey)
VALUES (0, ?, ?, ?);

-- ---- destinations --------------------------------------------------

CREATE TABLE destinations (
    hash          TEXT    NOT NULL PRIMARY KEY,
    identityHash  TEXT    NOT NULL,
    publicKey     BLOB    NOT NULL,
    destHash      BLOB    NOT NULL,
    nameHash      BLOB    NOT NULL,
    ratchetPub    BLOB,
    displayName   TEXT    NOT NULL,
    appName       TEXT,
    appLabel      TEXT,
    telemetryJson TEXT,
    lat           REAL,
    lon           REAL,
    appDataHex    TEXT    NOT NULL,
    lastSeen      INTEGER NOT NULL,
    rssi          INTEGER,
    favorite      INTEGER NOT NULL,
    source        TEXT    NOT NULL,
    hidden        INTEGER NOT NULL DEFAULT 0,
    hopCount      INTEGER NOT NULL DEFAULT 0,
    nextHop       BLOB,
    userLabel     TEXT
);

upsertDestination:
INSERT OR REPLACE INTO destinations (
    hash, identityHash, publicKey, destHash, nameHash, ratchetPub,
    displayName, appName, appLabel, telemetryJson, lat, lon,
    appDataHex, lastSeen, rssi, favorite, source, hidden, hopCount,
    nextHop, userLabel
) VALUES (
    ?, ?, ?, ?, ?, ?,
    ?, ?, ?, ?, ?, ?,
    ?, ?, ?, ?, ?, ?, ?,
    ?, ?
);

selectDestination:
SELECT *
FROM destinations
WHERE hash = ?
LIMIT 1;

selectAllDestinations:
SELECT *
FROM destinations
WHERE hidden = 0
ORDER BY lastSeen DESC;

observeAllDestinations:
SELECT *
FROM destinations
WHERE hidden = 0
ORDER BY favorite DESC, lastSeen DESC;

setFavorite:
UPDATE destinations
SET favorite = ?, hidden = 0
WHERE hash = ?;

setUserLabel:
UPDATE destinations
SET userLabel = ?
WHERE hash = ?;

hideDestination:
UPDATE destinations
SET hidden = 1
WHERE hash = ?;

deleteAllDestinations:
DELETE FROM destinations;

-- MED-2 announce-flood eviction. Hard-deletes the oldest
-- non-favorited, non-user-labeled, non-hidden rows past
-- the keep count. Favorites and renamed entries are preserved
-- regardless. Audit reference: 2026-05-13 MED-2.
evictUnfavoritedOldest:
DELETE FROM destinations
WHERE hash IN (
    SELECT hash FROM destinations
    WHERE favorite = 0
      AND hidden = 0
      AND (userLabel IS NULL OR userLabel = '')
    ORDER BY lastSeen DESC
    LIMIT -1 OFFSET ?
);

-- ---- messages ------------------------------------------------------

CREATE TABLE messages (
    id           INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    contactHash  TEXT    NOT NULL,
    direction    TEXT    NOT NULL,
    content      TEXT    NOT NULL,
    title        TEXT    NOT NULL,
    timestamp    INTEGER NOT NULL,
    state        TEXT,
    attempts     INTEGER NOT NULL,
    lastAttempt  INTEGER NOT NULL,
    lastError    TEXT,
    rawPacket    BLOB,
    packetHash   TEXT,
    rssi         INTEGER,
    hopCount     INTEGER,
    imageBytes   BLOB
);

insertMessage:
INSERT INTO messages (
    contactHash, direction, content, title, timestamp, state,
    attempts, lastAttempt, lastError, rawPacket, packetHash, rssi,
    hopCount, imageBytes
) VALUES (
    ?, ?, ?, ?, ?, ?,
    ?, ?, ?, ?, ?, ?,
    ?, ?
);

lastInsertRowId:
SELECT last_insert_rowid();

selectMessageById:
SELECT *
FROM messages
WHERE id = ?
LIMIT 1;

-- id ASC tie-break is load-bearing: two messages saved within the same
-- millisecond would otherwise flip order between consecutive observe*
-- emissions, surfacing as "the bubbles reorder themselves" on rapid
-- bursts (e.g. /users reply landing alongside an outgoing drain after
-- a transport reconnect). Mirrors the Room queries in Daos.kt.
selectMessagesForContact:
SELECT *
FROM messages
WHERE contactHash = ?
ORDER BY timestamp ASC, id ASC;

observeMessagesForContact:
SELECT *
FROM messages
WHERE contactHash = ?
ORDER BY timestamp ASC, id ASC;

selectAllMessages:
SELECT *
FROM messages
ORDER BY timestamp ASC, id ASC;

-- Prefix LIKE so both pre-v1.1.22 truncated (32 hex char) and v1.1.22+
-- full (64 hex char) packetHash values match against the inbound
-- PROOF's 32-char truncated dest_hash. The full form is needed by the
-- PROOF handler to Ed25519-verify the sig (SPEC §6.5.5).
selectOutgoingByPacketHash:
SELECT *
FROM messages
WHERE packetHash LIKE :hash || '%' AND direction = 'outgoing'
LIMIT 1;

observeIncomingContactHashes:
SELECT DISTINCT contactHash
FROM messages
WHERE direction = 'incoming';

-- COALESCE-based partial update: each parameter is nullable; passing
-- NULL leaves the column unchanged. Mirrors the Room DAO's
-- updateState() exactly so iOS code calls it identically.
--
-- Named bindings (:state, :attempts, ...) so SQLDelight generates
-- a Kotlin function with those parameter names; without them
-- repeated `?` would generate positional `value`/`value_`/`value__`
-- names that the iOS-side caller can't address by name.
updateMessageState:
UPDATE messages
SET state       = COALESCE(:state,       state),
    attempts    = COALESCE(:attempts,    attempts),
    lastAttempt = COALESCE(:lastAttempt, lastAttempt),
    lastError   = COALESCE(:lastError,   lastError),
    packetHash  = COALESCE(:packetHash,  packetHash)
WHERE id = :id;

deleteMessagesForContact:
DELETE FROM messages
WHERE contactHash = ?;

-- ---- nomad_page_cache ---------------------------------------------

CREATE TABLE nomad_page_cache (
    destHash    TEXT    NOT NULL,
    path        TEXT    NOT NULL,
    source      TEXT    NOT NULL,
    fetchedAt   INTEGER NOT NULL,
    byteSize    INTEGER NOT NULL,
    PRIMARY KEY (destHash, path)
);

upsertCachedPage:
INSERT OR REPLACE INTO nomad_page_cache (destHash, path, source, fetchedAt, byteSize)
VALUES (?, ?, ?, ?, ?);

selectCachedPage:
SELECT *
FROM nomad_page_cache
WHERE destHash = ? AND path = ?
LIMIT 1;

anyCachedForDest:
SELECT EXISTS(
    SELECT 1 FROM nomad_page_cache WHERE destHash = ? LIMIT 1
);

observeCachedDestHashes:
SELECT DISTINCT destHash
FROM nomad_page_cache;

deleteCachedPage:
DELETE FROM nomad_page_cache
WHERE destHash = ? AND path = ?;

deleteCachedForDest:
DELETE FROM nomad_page_cache
WHERE destHash = ?;

deleteAllCached:
DELETE FROM nomad_page_cache;
