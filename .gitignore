# Gradle
.gradle/
build/
local.properties
# F-Droid generates this on their build server (gradlew-fdroid
# --write-verification-metadata). Committing our own can conflict
# with their reproducible-build process — keep it local.
gradle/verification-metadata.xml

# IDE
.idea/
*.iml

# OS
.DS_Store
Thumbs.db

# Signing keys — NEVER commit
*.keystore
*.keystore.b64
*.jks

# Capacitor (not used here, but just in case)
www/

# Claude Code per-project state
.claude/

# In-flight private security advisories — kept local until coordinated
# disclosure is complete. Move out of this directory or remove the
# gitignore entry once the advisories have been accepted / patched /
# published upstream.
docs/security-advisories/

# Branding ZIPs are processed into androidApp/src/main/res; the rendered
# mipmap PNGs and androidApp/branding/*.svg are the sources of truth.
icon.zip
# binaries downloaded for local debugging — never commit
androidApp-release.apk
androidApp-release.aab
app-screen*.png
apks/
test-shots/

*Zone.Identifier
