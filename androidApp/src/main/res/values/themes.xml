<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Empty Compose-friendly base. The Compose theme (ReticulumTheme)
         supplies the actual color scheme. Setting NoActionBar means the
         Activity does not draw an XML-defined ActionBar that would
         conflict with the Compose Scaffold. -->
    <style name="Theme.Reticulum" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
    </style>
</resources>
