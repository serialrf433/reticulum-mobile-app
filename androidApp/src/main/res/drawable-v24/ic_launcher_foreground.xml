<?xml version="1.0" encoding="utf-8"?>
<!--
  Reticulum logo-mark glyph: a centred dot in #E1F5EE on the brand
  background. Matches the webclient's `.logo-mark::before { content: "·" }`
  pseudo-element and the embedded SVG favicon in index.html.

  Adaptive icons clip to a 72dp safe zone inside the 108dp viewport, so
  the dot is sized to read clearly even after the launcher's mask shape
  is applied.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Circle centred at (54, 54) with radius 14. -->
    <path
        android:fillColor="#E1F5EE"
        android:pathData="M 54 54 m -14 0 a 14 14 0 1 0 28 0 a 14 14 0 1 0 -28 0 Z" />
</vector>
