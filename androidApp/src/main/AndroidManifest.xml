<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- BLE permissions (Android 12+) -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
                     android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-feature android:name="android.hardware.bluetooth_le" android:required="true" />

    <!-- Bluetooth Classic (RFCOMM/SPP) on pre-Android-12. BLUETOOTH_CONNECT
         above covers Classic on API 31+. -->
    <uses-permission android:name="android.permission.BLUETOOTH"
                     android:maxSdkVersion="30" />

    <!-- Foreground service for background BLE monitoring -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    <!-- dataSync FGS type for TCP-only connections: connectedDevice (above)
         requires a granted Bluetooth runtime permission on Android 14+, which
         a TCP-only user who denied BLE doesn't have (issue #35). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Network for TCP transport + map tiles -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Camera for QR scanning on the Nodes tab -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Microphone for recording LXMF voice clips (FIELD_AUDIO) -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.microphone" android:required="false" />

    <!-- USB host for a USB-attached RNode (issue #41, experimental). Not
         required so the app still installs on phones without USB-OTG. No
         <uses-permission> exists for USB host; per-device access is granted
         at runtime via UsbManager.requestPermission. -->
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <!-- Battery-optimization exemption. The foreground service holds
         a long-lived BLE/TCP connection; vendor-specific battery
         management (Samsung Device Care, Xiaomi MIUI restrictions,
         OnePlus Adaptive Battery) aggressively kills "optimized"
         foreground services after a few minutes of screen-off
         despite the spec saying foreground services are exempt.
         Settings → Status section offers a one-tap "Disable battery
         optimization for Reticulum" button that fires the system
         dialog gated behind this permission. The user can decline;
         the app still works, it just reconnects more often. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!--
        Auto Backup disabled. The Room DB stores the Reticulum identity
        (X25519 + Ed25519 + ratchet) as plain BLOB rows in the `identity`
        table. If included in Auto Backup / `adb backup` the keys flow to
        the user's Google Drive (or wherever the device sync ships
        backups) and to anyone who can trigger a restore. Users who want
        a real backup should use Settings → Export Identity which
        produces a passphrase-encrypted `.rmid` archive via
        IdentityArchive (PBKDF2-HMAC-SHA256 600k iters, AES-CBC, HMAC).
        Audit reference: 2026-05-13 HIGH-1.
    -->
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Reticulum">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|uiMode|keyboard|keyboardHidden"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- QR scanner, pinned to portrait. zxing-android-embedded's
             stock CaptureActivity follows the sensor; this subclass +
             screenOrientation forces the camera preview upright. See
             PortraitCaptureActivity.kt. -->
        <activity
            android:name=".platform.PortraitCaptureActivity"
            android:screenOrientation="portrait"
            android:stateNotNeeded="true"
            android:exported="false"
            android:theme="@style/zxing_CaptureTheme" />

        <service
            android:name=".service.ReticulumService"
            android:foregroundServiceType="connectedDevice|dataSync"
            android:exported="false" />

    </application>
</manifest>
